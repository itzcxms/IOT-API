{
  "name": "iot-api",
  "version": "1.0.0",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "seed:rbac": "node script/seedRbac.js",
    "test": "set NODE_ENV= test && jest",
    "test:watch": "set NODE_ENV= test && jest --watchAll"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.20.1",
    "morgan": "^1.10.1",
    "supertest": "^7.1.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.11"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatters": [
      "/node_modules"
    ],
    "testPathIgnorePatterns": [
      "/node_modules",
      "/__tests__/mocks/",
      "/db\\.test\\.js$"
    ],
    "setupFilesAfterEnv": [
      "./jest.setup.js"
    ]
  }
